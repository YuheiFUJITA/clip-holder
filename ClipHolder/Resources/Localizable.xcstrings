    "Accessibility permission is required\nto monitor the clipboard. Please grant it below." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Für die Überwachung der Zwischenablage\nist die Bedienungshilfen-Berechtigung erforderlich. Bitte erteile sie unten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se requiere permiso de accesibilidad\npara monitorizar el portapapeles. Concédelo desde el botón inferior."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'autorisation d'accessibilité est requise\npour surveiller le presse-papiers. Veuillez l'accorder ci-dessous."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per monitorare gli appunti è necessaria\nl'autorizzazione di accessibilità. Concedila dal pulsante qui sotto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "クリップボードの監視にはアクセシビリティ\n権限が必要です。下のボタンから設定してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "클립보드 모니터링에는\n손쉬운 사용 권한이 필요합니다. 아래 버튼에서 설정하십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "É necessária a permissão de acessibilidade\npara monitorar a área de transferência. Conceda-a abaixo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Для отслеживания буфера обмена\nтребуется разрешение универсального доступа. Предоставьте его ниже."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "监控剪贴板需要\n辅助功能权限。请在下方授予权限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "監控剪貼簿需要\n輔助使用權限。請於下方授予權限。"
          }
        }
      }
    },

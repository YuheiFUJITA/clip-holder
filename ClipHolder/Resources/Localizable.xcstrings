    "Automatically record everything you copy.\nRetrieve past clips anytime." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeichnet automatisch alles auf, was du kopierst.\nRufe frühere Einträge jederzeit ab."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra automáticamente todo lo que copias.\nRecupera copias anteriores en cualquier momento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistre automatiquement tout ce que vous copiez.\nRetrouvez à tout moment les copies précédentes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra automaticamente tutto ciò che copi.\nRecupera le copie precedenti in qualsiasi momento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コピーした内容を自動で記録。\nいつでも過去のコピーを呼び出せます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "복사한 모든 내용을 자동으로 기록합니다.\n언제든지 이전 복사 내용을 불러올 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra automaticamente tudo o que você copia.\nAcesse cópias anteriores a qualquer momento."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Автоматически сохраняет всё, что вы копируете.\nВозвращайтесь к предыдущим записям в любое время."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自动记录您复制的所有内容。\n随时调取以往的剪贴记录。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自動記錄您複製的所有內容。\n隨時取回過往的剪貼記錄。"
          }
